// Prisma Schema — YouTube Watch Pool
// Veritabanı: SQLite (Prisma v5, dosya tabanlı)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Kullanıcı Modeli ────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  points       Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  videos            Video[]
  watchSessions     WatchSession[]
  pointTransactions PointTransaction[]

  @@map("users")
}

// ─── Video Modeli ────────────────────────────────────────────
model Video {
  id              String   @id @default(cuid())
  youtubeUrl      String
  youtubeId       String
  title           String
  description     String?
  thumbnailUrl    String?
  durationSeconds Int      @default(0)
  costPoints      Int      @default(50)
  rewardPoints    Int      @default(10)
  isActive        Boolean  @default(true)
  totalViews      Int      @default(0)
  ownerId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  watchSessions WatchSession[]

  @@map("videos")
}

// ─── İzleme Seansı Modeli ────────────────────────────────────
model WatchSession {
  id             String    @id @default(cuid())
  userId         String
  videoId        String
  watchedSeconds Int       @default(0)
  totalSeconds   Int       @default(0)
  rewarded       Boolean   @default(false)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@map("watch_sessions")
}

// ─── Puan İşlemi Modeli ──────────────────────────────────────
// type: "REGISTER_BONUS" | "WATCH_REWARD" | "VIDEO_SUBMIT"
model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}
